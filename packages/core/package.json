    "js-yaml": "^4.1",
    "mdast-util-from-markdown": "^2.0.3",
    "pptxgenjs": "^3.12.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "shiki": "^4.0.2",
    "unified": "^11.0.5",
    "zod": "^3.23"
  },
  "devDependencies": {
