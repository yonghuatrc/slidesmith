{
  "name": "@slidesmith/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "slidesmith": "./dist/cli.cjs"
  },
  "exports": {
    "./config": "./src/config/index.ts",
    "./parser": "./src/parser/index.ts",
    "./cli": "./src/cli/index.ts",
    "./preview": "./src/preview/index.ts"
  },
  "scripts": {
